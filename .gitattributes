# Normalize line endings: text is LF in the repo (keeps CI/Linux clean).
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.svg text eol=lf
*.pmtiles binary
*.ttf binary

# Gzipped daily aggregates are binary — MUST NOT be eol-normalized (that would
# corrupt the gzip stream). This overrides the "* text=auto" rule above.
*.gz binary

# Generated/data JSON is text; large but small per file.
data/**/*.json text eol=lf
